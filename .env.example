# .env.example — Required environment variables for tiered AI access

# Database (Neon Postgres — set when you add the Neon integration on Vercel)
DATABASE_URL=

# Redis (Upstash — set when you add the Upstash Redis integration on Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# JWT secret for session tokens (generate a random 64-char string)
JWT_SECRET=

# OAuth: GitHub (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth: Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# OAuth redirect URL (must match what's set in GitHub/Google console)
# Example: https://your-app.vercel.app/api/auth/callback
OAUTH_REDIRECT_URL=

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_CREDITS_PRICE_ID=

# Number of AI calls in a credit pack (default 100)
CREDITS_PACK_AMOUNT=100

# Server-side AI provider API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# DB init secret (any random string, used to protect /api/init-db)
DB_INIT_SECRET=

# App URL (used as fallback for Stripe redirect URLs)
APP_URL=https://your-app.vercel.app
